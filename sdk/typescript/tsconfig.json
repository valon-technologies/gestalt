{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": [
      "bun"
    ]
  },
  "include": [
    "docs/entrypoints/**/*.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "src/internal/gen/**/*.ts"
  ]
}
