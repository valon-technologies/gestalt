#!/usr/bin/env bash
#
# Pre-push hook: runs the same lint/format checks as CI.
# Only checks areas of the codebase that have changed on this branch.
#
# Bypass with: git push --no-verify
# Setup:       git config core.hooksPath .githooks

set -euo pipefail

# --- Helpers ----------------------------------------------------------------

red()    { printf '\033[1;31m%s\033[0m\n' "$*"; }
green()  { printf '\033[1;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[1;33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

has() { command -v "$1" &>/dev/null; }

fail() {
    red "FAILED: $1"
    exit 1
}

# Run an npm script in a subdirectory, skipping if npm or node_modules is missing.
check_npm() {
    local dir=$1 label=$2 script=$3
    if has_changes_in "^${dir}/"; then
        if has npm; then
            if [ -d "${dir}/node_modules" ]; then
                ran_any=true
                bold "==> ${label}"
                (cd "$dir" && npm run "$script") || fail "$label"
            else
                yellow "==> ${label}: skipping (run 'npm ci' in ${dir}/ first)"
            fi
        else
            yellow "==> ${label}: skipping (npm not installed)"
        fi
    fi
}

# --- Determine changed files ------------------------------------------------

# Find the merge-base with main to know what this branch changed.
# On main itself this produces an empty diff, so no checks run (CI covers main).
base=$(git merge-base HEAD main 2>/dev/null || echo HEAD~1)
changed_files=$(git diff --name-only "$base"...HEAD 2>/dev/null || git diff-tree --no-commit-id --name-only -r HEAD)

has_changes_in() {
    echo "$changed_files" | grep -qE "$1"
}

ran_any=false

# --- Go checks --------------------------------------------------------------

if has_changes_in '\.go$|go\.(mod|sum)$'; then
    if has go; then
        ran_any=true
        bold "==> Go: mod tidy"
        go mod tidy || fail "go mod tidy"
        git diff --exit-code go.mod go.sum || fail "go.mod/go.sum not tidy, commit the changes"
    fi

    if has golangci-lint; then
        ran_any=true
        bold "==> Go: golangci-lint"
        golangci-lint run ./... || fail "golangci-lint"
    else
        yellow "==> Go: skipping lint (golangci-lint not installed)"
    fi
fi

# --- Web + Docs checks ------------------------------------------------------

check_npm web  "Web: typecheck + lint" check
check_npm docs "Docs: typecheck"       typecheck

# --- Rust checks -------------------------------------------------------------

if has_changes_in '^client/'; then
    if has cargo; then
        ran_any=true
        bold "==> Rust: fmt"
        (cd client && cargo fmt --all -- --check) || fail "cargo fmt"

        bold "==> Rust: clippy"
        (cd client && cargo clippy --workspace --all-targets -- -D warnings) || fail "cargo clippy"
    else
        yellow "==> Rust: skipping (cargo not installed)"
    fi
fi

# --- Done --------------------------------------------------------------------

if [ "$ran_any" = true ]; then
    green "All pre-push checks passed."
fi
